{
    "type": "classique-cards-card-image",
    "template": "html",
    "kind": "static",
    "id": "card-image",
    "label": "Card image",
    "category": "classic",
    "subcategory": "cards",
    "icon": "fa-image",
    "schema": {
        "image": {
            "type": "string",
            "label": "Image — URL",
            "default": "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=500&fit=crop"
        },
        "image_alt": {
            "type": "string",
            "label": "Image — texte alt",
            "default": "Illustration"
        },
        "subtitle": {
            "type": "string",
            "label": "Sous-titre",
            "multiline": true,
            "default": "Sous-titre descriptif pour accompagner votre message."
        },
        "paragraph": {
            "type": "string",
            "label": "Paragraphe",
            "multiline": true,
            "default": "Texte de paragraphe."
        }
    },
    "defaults": {
        "image": "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=500&fit=crop",
        "image_alt": "Illustration",
        "subtitle": "Sous-titre",
        "paragraph": "Texte de paragraphe.",
        "htmlTemplate": "<section class=\"p-[48px_40px] bg-[var(--bg)]\"><div class=\"bg-[var(--surface)] border border-[var(--line)] rounded-[18px] overflow-hidden max-w-[360px]\"><img class=\"w-full h-[200px] object-cover\" src=\"{{image}}\" alt=\"{{image_alt}}\"><div class=\"p-[24px]\"><h3 class=\"text-[16px] font-extrabold text-[var(--text)] mb-[8px]\">{{subtitle}}</h3><p class=\"text-[14px] text-[var(--muted)] leading-[1.65]\">{{paragraph}}</p></div></div></section>"
    },
    "astroTemplate": "Html.astro",
    "legacy": {
        "originalType": "classique",
        "id": "card-image"
    }
}