    "html": "<section id=\"gv-navbar-1\" data-gv-block=\"1\" data-gv-block-type=\"navbar\" data-gv-variant=\"1\" data-gv-block-id=\"gv-navbar-1\"><style>:root{--bg:#0f1115;--surface:#151923;--text:#f5f6f7;--muted:#b4bac7;--brand:#f97316;--line:rgba(255,255,255,.09);--font-title:system-ui,-apple-system,sans-serif;--font-subtitle:system-ui,-apple-system,sans-serif;--font-body:system-ui,-apple-system,sans-serif}*{box-sizing:border-box;margin:0;padding:0}body{font-family:var(--font-body),system-ui,sans-serif;background:var(--bg);color:var(--text)}h1,h2{font-family:var(--font-title),system-ui,sans-serif}h3,h4,h5,h6{font-family:var(--font-subtitle),system-ui,sans-serif}a{text-decoration:none;color:inherit}button{cursor:pointer;font:inherit}img{max-width:100%;height:auto}@media(max-width:768px){[style*=\"grid-template-columns:repeat(3\"],[style*=\"grid-template-columns:repeat(4\"],[style*=\"grid-template-columns:1fr 1fr\"],[style*=\"grid-template-columns:2fr 1fr\"],[style*=\"grid-template-columns:1fr 2fr\"],[style*=\"grid-template-columns:1.2fr 1fr\"],[style*=\"grid-template-columns:1fr 1.2fr\"],[style*=\"grid-template-columns:1.6fr 1fr\"],[style*=\"grid-template-columns:1fr 1.6fr\"],[style*=\"grid-template-columns:1.8fr 1fr\"],[style*=\"grid-template-columns:1.8fr 1fr 1fr\"],[style*=\"grid-template-columns:2fr 1fr 1fr\"],[style*=\"grid-template-columns:1fr 2.5fr\"],[style*=\"grid-template-columns:auto 1fr\"],[style*=\"grid-template-columns:80px 1fr\"],[style*=\"grid-template-columns:columns:3\"]{grid-template-columns:1fr!important}.h-split{grid-template-columns:1fr!important}[style*=\"padding:72px 48px\"],[style*=\"padding:72px 40px\"],[style*=\"padding:80px 40px\"],[style*=\"padding:80px 48px\"],[style*=\"padding:88px 48px\"],[style*=\"padding:64px 48px\"],[style*=\"padding:64px 40px\"],[style*=\"padding:56px 48px\"],[style*=\"padding:56px 40px\"]{padding-top:40px!important;padding-bottom:40px!important;padding-left:20px!important;padding-right:20px!important}[style*=\"padding:0 48px\"],[style*=\"padding:0 40px\"],[style*=\"padding:0 32px\"]{padding-left:16px!important;padding-right:16px!important}[style*=\"columns:3\"]{columns:1!important}}@media(max-width:480px){.h-title{font-size:1.8rem!important}[style*=\"font-size:4rem\"],[style*=\"font-size:3.6rem\"],[style*=\"font-size:3.4rem\"],[style*=\"font-size:3.2rem\"],[style*=\"font-size:3rem\"]{font-size:2rem!important}[style*=\"font-size:2.8rem\"],[style*=\"font-size:2.4rem\"]{font-size:1.8rem!important}}/* nav shared */.nav-links{display:flex;gap:20px;font-size:13px}@media(max-width:768px){.nav-links{display:none!important}.nav-ham{display:flex!important}}.nav-ham{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:6px}.nav-ham span{width:20px;height:2px;background:var(--text);border-radius:2px}.nav-cta{background:var(--brand);color:#fff;padding:8px 18px;border-radius:8px;font-size:13px;font-weight:700;transition:opacity .2s;white-space:nowrap}.nav-cta:hover{opacity:.85}/* btn shared */.h-cta1{background:var(--brand);color:#fff;padding:13px 32px;border-radius:10px;font-weight:700;font-size:14px;display:inline-flex;align-items:center;gap:8px;transition:opacity .2s,transform .2s;box-shadow:0 4px 20px color-mix(in srgb,var(--brand) 28%,transparent)}.h-cta1:hover{opacity:.88;transform:translateY(-1px)}.h-cta2{border:1.5px solid var(--line);color:var(--text);padding:13px 32px;border-radius:10px;font-weight:600;font-size:14px;display:inline-flex;align-items:center;gap:8px;transition:background .2s}.h-cta2:hover{background:rgba(128,128,128,.08)}.h-btns{display:flex;gap:12px;flex-wrap:wrap}@media(max-width:768px){.h-btns{flex-direction:column!important;align-items:stretch!important}.h-title{font-size:2.2rem!important}}.card-lift{transition:transform .22s cubic-bezier(.4,0,.2,1),border-color .22s}.card-lift:hover{transform:translateY(-3px);border-color:var(--brand)!important}.sec-head{text-align:center;margin-bottom:52px}.sec-kicker{font-size:11px;font-weight:700;color:var(--brand);letter-spacing:.13em;text-transform:uppercase;display:block;margin-bottom:12px}.sec-title{font-size:2rem;font-weight:900;color:var(--text);letter-spacing:-.025em;line-height:1.1;margin-bottom:12px}.sec-sub{color:var(--muted);font-size:14px;max-width:500px;margin:0 auto;line-height:1.72}</style>\r\n<nav style=\"background:var(--bg);border-bottom:1px solid var(--line);padding:0 40px;height:64px;display:flex;align-items:center;justify-content:space-between;gap:16px\">\r\n  <a href=\"#\" style=\"display:flex;align-items:center;gap:10px;flex-shrink:0\">\r\n    <div style=\"width:32px;height:32px;border-radius:9px;background:var(--brand);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:14px;color:#fff;box-shadow:0 0 14px color-mix(in srgb,var(--brand) 40%,transparent)\">G</div>\r\n    <b style=\"font-size:15px;color:var(--text);letter-spacing:-.3px\">{{brand.name}}</b>\r\n  </a>\r\n  <div class=\"nav-links\">\r\n    {{#navLinks}}<a style=\"color:var(--muted);transition:color .15s;font-weight:500;font-size:13.5px\" href=\"{{href}}\">{{label}}</a>{{/navLinks}}\r\n  </div>\r\n  <div style=\"display:flex;align-items:center;gap:10px\">\r\n    <a href=\"#\" style=\"color:var(--muted);font-size:13px;font-weight:600\">Se connecter</a>\r\n    <a class=\"nav-cta\" href=\"#\">{{cta.label}}</a>\r\n    <div class=\"nav-ham\"><span></span><span></span><span></span></div>\r\n  </div>\r\n</nav></section>"
