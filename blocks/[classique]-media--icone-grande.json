{
    "type": "classique-media-icone-grande",
    "template": "html",
    "kind": "static",
    "id": "icone-grande",
    "label": "Icône grande",
    "category": "classic",
    "subcategory": "media",
    "icon": "fa-star",
    "schema": {
        "text": {
            "type": "string",
            "label": "Texte",
            "multiline": true,
            "default": "Votre texte ici."
        },
        "subtitle": {
            "type": "string",
            "label": "Sous-titre",
            "multiline": true,
            "default": "Sous-titre descriptif pour accompagner votre message."
        },
        "paragraph": {
            "type": "string",
            "label": "Paragraphe",
            "multiline": true,
            "default": "Texte de paragraphe."
        }
    },
    "defaults": {
        "text": "Texte",
        "subtitle": "Sous-titre",
        "paragraph": "Texte de paragraphe.",
        "htmlTemplate": "<bloc class=\"p-[48px_40px] bg-[var(--bg)] text-center\"><span class=\"inline-flex w-[80px] h-[80px] rounded-[20px] flex items-center justify-center mx-auto mb-[16px] bg-[color:var(--brand12)]\"><span class=\"text-[var(--brand)] text-[36px]\">{{text}}</span></span><h3 class=\"text-[18px] font-extrabold text-[var(--text)] mb-[8px]\">{{subtitle}}</h3><p class=\"text-[14px] text-[var(--muted)] leading-[1.6] max-w-[400px] mx-auto\">{{paragraph}}</p></bloc>"
    },
    "astroTemplate": "Html.astro",
    "legacy": {
        "originalType": "classique",
        "id": "icone-grande"
    }
}