{
    "type": "classique-cards-card",
    "template": "html",
    "kind": "static",
    "id": "card",
    "label": "Card",
    "category": "classic",
    "subcategory": "cards",
    "icon": "fa-square",
    "schema": {
        "subtitle": {
            "type": "string",
            "label": "Sous-titre",
            "multiline": true,
            "default": "Sous-titre descriptif pour accompagner votre message."
        },
        "paragraph": {
            "type": "string",
            "label": "Paragraphe",
            "multiline": true,
            "default": "Texte de paragraphe."
        }
    },
    "defaults": {
        "subtitle": "Sous-titre",
        "paragraph": "Texte de paragraphe.",
        "htmlTemplate": "<bloc class=\"p-[48px_40px] bg-[var(--bg)]\"><div class=\"bg-[var(--surface)] border border-[var(--line)] rounded-[18px] p-[28px] max-w-[360px]\"><div class=\"text-[28px] mb-[14px]\">*</div><h3 class=\"text-[16px] font-extrabold text-[var(--text)] mb-[8px]\">{{subtitle}}</h3><p class=\"text-[14px] text-[var(--muted)] leading-[1.65]\">{{paragraph}}</p></div></bloc>"
    },
    "astroTemplate": "Html.astro",
    "legacy": {
        "originalType": "classique",
        "id": "card"
    }
}