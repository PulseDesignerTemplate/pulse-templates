{
    "type": "classique-mise-en-page-notification",
    "template": "html",
    "kind": "static",
    "id": "notification",
    "label": "Notification",
    "category": "classic",
    "subcategory": "mise-en-page",
    "icon": "fa-bell",
    "schema": {
        "text": {
            "type": "string",
            "label": "Texte",
            "multiline": true,
            "default": "Votre texte ici."
        },
        "paragraph": {
            "type": "string",
            "label": "Paragraphe",
            "multiline": true,
            "default": "Texte de paragraphe."
        }
    },
    "defaults": {
        "text": "Texte",
        "paragraph": "Texte de paragraphe.",
        "htmlTemplate": "<section class=\"p-[40px] bg-[var(--bg)]\"><div class=\"bg-[#dcfce7] border border-[#86efac] rounded-[12px] p-[16px_20px] max-w-[560px]\"><div class=\"flex items-center gap-[10px]\"><span class=\"inline-flex w-[20px] h-[20px] rounded-full bg-[#16a34a] flex items-center justify-center flex-shrink-0\"><span class=\"text-[#fff] text-[11px] font-bold\">{{text}}</span></span><p class=\"text-[14px] text-[#166534] font-medium\">{{paragraph}}</p></div></div></section>"
    },
    "astroTemplate": "Html.astro",
    "legacy": {
        "originalType": "classique",
        "id": "notification"
    }
}