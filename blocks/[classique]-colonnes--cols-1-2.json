{
    "type": "classique-colonnes-cols-1-2",
    "template": "html",
    "kind": "static",
    "id": "cols-1-2",
    "label": "Colonnes 1/3 + 2/3",
    "category": "classic",
    "subcategory": "colonnes",
    "icon": "fa-table-columns",
    "schema": {
        "subtitle": {
            "type": "string",
            "label": "Sous-titre",
            "multiline": true,
            "default": "Sous-titre descriptif pour accompagner votre message."
        },
        "paragraph": {
            "type": "string",
            "label": "Paragraphe",
            "multiline": true,
            "default": "Texte de paragraphe."
        },
        "paragraph_2": {
            "type": "string",
            "label": "Paragraphe 2",
            "multiline": true,
            "default": "paragraph_2"
        }
    },
    "defaults": {
        "subtitle": "Sous-titre",
        "paragraph": "Texte de paragraphe.",
        "paragraph_2": "Texte de paragraphe.",
        "htmlTemplate": "<bloc class=\"p-[60px_40px] bg-[var(--bg)]\"><div class=\"grid grid-cols-[1fr_2fr] gap-[32px] items-start\"><div><h3 class=\"text-[1.3rem] font-extrabold text-[var(--text)] leading-[1.3] mb-[8px]\">{{subtitle}}</h3><p class=\"text-[13px] text-[var(--muted)] leading-[1.6]\">{{paragraph}}</p></div><div class=\"bg-[var(--surface)] border border-[var(--line)] rounded-[16px] p-[28px]\"><p class=\"text-[14px] text-[var(--muted)] leading-[1.7]\">{{paragraph_2}}</p></div></div></bloc>"
    },
    "astroTemplate": "Html.astro",
    "legacy": {
        "originalType": "classique",
        "id": "cols-1-2"
    }
}