{
    "type": "classique-mise-en-page-breadcrumb",
    "template": "html",
    "kind": "static",
    "id": "breadcrumb",
    "label": "Fil d'Ariane",
    "category": "classic",
    "subcategory": "mise-en-page",
    "icon": "fa-angle-right",
    "schema": {
        "link_label": {
            "type": "string",
