{
    "type": "classique-cards-card-profil",
    "template": "html",
    "kind": "static",
    "id": "card-profil",
    "label": "Card profil",
    "category": "classic",
    "subcategory": "cards",
    "icon": "fa-user-circle",
    "schema": {
        "image": {
            "type": "string",
            "label": "Image — URL",
            "default": "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=500&fit=crop"
        },
        "image_alt": {
            "type": "string",
            "label": "Image — texte alt",
            "default": "Illustration"
        },
        "subtitle": {
            "type": "string",
            "label": "Sous-titre",
            "multiline": true,
            "default": "Sous-titre descriptif pour accompagner votre message."
        },
        "paragraph": {
            "type": "string",
            "label": "Paragraphe",
            "multiline": true,
            "default": "Texte de paragraphe."
        },
        "paragraph_2": {
            "type": "string",
            "label": "Paragraphe 2",
            "multiline": true,
            "default": "paragraph_2"
        }
    },
    "defaults": {
        "image": "https://images.unsplash.com/photo-1497366216548-37526070297c?w=800&h=500&fit=crop",
        "image_alt": "Illustration",
        "subtitle": "Sous-titre descriptif pour accompagner votre message.",
        "paragraph": "Texte de paragraphe.",
        "paragraph_2": "Texte de paragraphe.",
        "htmlTemplate": "<section class=\"p-[48px_40px] bg-[var(--bg)]\"><div class=\"bg-[var(--surface)] border border-[var(--line)] rounded-[18px] p-[28px] max-w-[300px] text-center\"><img class=\"w-[72px] h-[72px] rounded-full mx-auto mb-[16px] object-cover border-[2px] border-[var(--line)]\" src=\"{{image}}\" alt=\"{{image_alt}}\"><h3 class=\"text-[16px] font-extrabold text-[var(--text)] mb-[4px]\">{{subtitle}}</h3><p class=\"text-[13px] text-[var(--brand)] font-semibold mb-[10px]\">{{paragraph}}</p><p class=\"text-[13px] text-[var(--muted)] leading-[1.6]\">{{paragraph_2}}</p></div></section>"
    },
    "astroTemplate": "Html.astro",
    "legacy": {
        "originalType": "classique",
        "id": "card-profil"
    }
}