adding:0 48px\"],[style*=\"padding:0 40px\"],[style*=\"padding:0 32px\"]{padding-left:16px!important;padding-right:16px!important}[style*=\"columns:3\"]{columns:1!important}}@media(max-width:480px){.h-title{font-size:1.8rem!important}[style*=\"font-size:4rem\"],[style*=\"font-size:3.6rem\"],[style*=\"font-size:3.4rem\"],[style*=\"font-size:3.2rem\"],[style*=\"font-size:3rem\"]{font-size:2rem!important}[style*=\"font-size:2.8rem\"],[style*=\"font-size:2.4rem\"]{font-size:1.8rem!important}}/* nav shared */.nav-links{display:flex;gap:20px;font-size:13px}@media(max-width:768px){.nav-links{display:none!important}.nav-ham{display:flex!important}}.nav-ham{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:6px}.nav-ham span{width:20px;height:2px;background:var(--text);border-radius:2px}.nav-cta{background:var(--brand);color:#fff;padding:8px 18px;border-radius:8px;font-size:13px;font-weight:700;transition:opacity .2s;white-space:nowrap}.nav-cta:hover{opacity:.85}/* btn shared */.h-cta1{background:var(--brand);color:#fff;padding:13px 32px;border-radius:10px;font-weight:700;font-size:14px;display:inline-flex;align-items:center;gap:8px;transition:opacity .2s,transform .2s;box-shadow:0 4px 20px color-mix(in srgb,var(--brand) 28%,transparent)}.h-cta1:hover{opacity:.88;transform:translateY(-1px)}.h-cta2{border:1.5px solid var(--line);color:var(--text);padding:13px 32px;border-radius:10px;font-weight:600;font-size:14px;display:inline-flex;align-items:center;gap:8px;transition:background .2s}.h-cta2:hover{background:rgba(128,128,128,.08)}.h-btns{display:flex;gap:12px;flex-wrap:wrap}@media(max-width:768px){.h-btns{flex-direction:column!important;align-items:stretch!important}.h-title{font-size:2.2rem!important}}.card-lift{transition:transform .22s cubic-bezier(.4,0,.2,1),border-color .22s}.card-lift:hover{transform:translateY(-3px);border-color:var(--brand)!important}.sec-head{text-align:center;margin-bottom:52px}.sec-kicker{font-size:11px;font-weight:700;color:var(--brand);letter-spacing:.13em;text-transform:uppercase;display:block;margin-bottom:12px}.sec-title{font-size:2rem;font-weight:900;color:var(--text);letter-spacing:-.025em;line-height:1.1;margin-bottom:12px}.sec-sub{color:var(--muted);font-size:14px;max-width:500px;margin:0 auto;line-height:1.72}</style><footer style=\"background:var(--surface);border-top:1px solid var(--line);padding:72px 40px 40px\">\r\n  <div style=\"max-width:1000px;margin:0 auto\">\r\n    <div style=\"text-align:center;margin-bottom:48px\">\r\n      <div style=\"font-size:2rem;font-weight:900;color:var(--text);margin-bottom:10px\">{{brand.name}}</div>\r\n      <p style=\"color:var(--muted);font-size:13.5px;max-width:460px;margin:0 auto 20px;line-height:1.65\">{{subtitle}}</p>\r\n      <a style=\"background:var(--brand);color:#fff;padding:12px 32px;border-radius:10px;font-weight:700;font-size:14px;display:inline-block\">{{cta.label}}</a>\r\n    </div>\r\n    <div style=\"display:flex;justify-content:center;gap:32px;flex-wrap:wrap;margin-bottom:36px\">\r\n      {{#navLinks}}<a style=\"color:var(--muted);font-size:13px\" href=\"{{href}}\">{{label}}</a>{{/navLinks}}\r\n    </div>\r\n    <div style=\"padding-top:28px;border-top:1px solid var(--line);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px\">\r\n      <span style=\"font-size:12px;color:var(--muted)\">&copy; {{year}} {{company}}</span>\r\n      <div style=\"display:flex;gap:8px\">\r\n        {{#socials}}<a href=\"{{href}}\" style=\"color:var(--muted);font-size:13px;width:30px;height:30px;border:1px solid var(--line);border-radius:8px;display:flex;align-items:center;justify-content:center\">{{icon}}</a>{{/socials}}\r\n      </div>\r\n    </div>\r\n  </div>\r\n</footer></section>"
