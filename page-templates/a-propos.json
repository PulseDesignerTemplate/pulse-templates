        "sourceLabel": "Notre mission",
        "category": "about",
        "rawHtml": "<section class=\"bg-[var(--bg)] p-[80px_40px]\"><div class=\"grid grid-cols-2 gap-[48px] items-center max-w-[960px] mx-auto\"><div><span class=\"text-[11px] font-bold text-[var(--brand)] tracking-[.13em] uppercase block mb-[14px]\">A propos</span><h2 class=\"text-[2rem] font-black text-[var(--text)] tracking-[-.025em] leading-[1.1] mb-[16px]\">Notre mission</h2><p class=\"text-[14px] text-[var(--muted)] leading-[1.75] mb-[20px]\">Nous croyons que chaque entreprise merite des outils puissants et accessibles. Notre equipe travaille chaque jour pour simplifier votre quotidien.</p><div class=\"flex gap-[24px]\"><div><div class=\"text-[1.8rem] font-black text-[var(--brand)]\">50+</div><div class=\"text-[12px] text-[var(--muted)] font-medium\">Experts</div></div><div><div class=\"text-[1.8rem] font-black text-[var(--brand)]\">12</div><div class=\"text-[12px] text-[var(--muted)] font-medium\">Pays</div></div><div><div class=\"text-[1.8rem] font-black text-[var(--brand)]\">2019</div><div class=\"text-[12px] text-[var(--muted)] font-medium\">Fondee</div></div></div></div><div class=\"bg-[var(--surface)] border border-[var(--line)] rounded-[20px] h-[320px] flex items-center justify-center text-[var(--muted)] text-[14px]\">Photo equipe</div></div></section>"
      }
